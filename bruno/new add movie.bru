meta {
  name: Create Movie
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/api/movies
  body: json
  auth: bearer
}

headers {
  Authorization: Bearer {{token}}
}

body:json {
  {
    "name": "Inception",
    "year": 2010,
    "description": "Un ladrón que roba secretos mediante sueños es contratado para implantar una idea.",
    "category": "Ciencia ficción"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}